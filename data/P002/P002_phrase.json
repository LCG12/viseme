{
  "paragraph_id": "P002",
  "phrases": [
    {
      "phrase_idx": 0,
      "text": "仿真机器人有望通过逼真的面部表情实现自然的人机交互",
      "punctuation": "。"
    },
    {
      "phrase_idx": 1,
      "text": "然而",
      "punctuation": "，"
    },
    {
      "phrase_idx": 2,
      "text": "由于面部生物力学的复杂性以及对响应式运动合成的需求",
      "punctuation": "，"
    },
    {
      "phrase_idx": 3,
      "text": "生成逼真且与语音同步的机器人表情面临着巨大的挑战",
      "punctuation": "。"
    },
    {
      "phrase_idx": 4,
      "text": "本文提出了一种以蒙皮为中心的新方法",
      "punctuation": "，"
    },
    {
      "phrase_idx": 5,
      "text": "利用语音输入驱动仿真机器人的面部表情",
      "punctuation": "。"
    },
    {
      "phrase_idx": 6,
      "text": "该方法的核心是采用线性混合蒙皮（LBS）作为统一的表示方法",
      "punctuation": "，"
    },
    {
      "phrase_idx": 7,
      "text": "从而指导实体设计和运动合成方面的创新",
      "punctuation": "。"
    },
    {
      "phrase_idx": 8,
      "text": "LBS能够指导驱动拓扑结构",
      "punctuation": "，"
    },
    {
      "phrase_idx": 9,
      "text": "促进人类表情的重定向",
      "punctuation": "，"
    },
    {
      "phrase_idx": 10,
      "text": "并实现高效的语音驱动面部运动生成",
      "punctuation": "。"
    },
    {
      "phrase_idx": 11,
      "text": "该方法在单块NvidiaRTX4090显卡上实现了超过4000fps的实时仿真面部表情生成能力",
      "punctuation": "，"
    },
    {
      "phrase_idx": 12,
      "text": "显著提升了机器人复制细微人类表情以实现自然交互的能力",
      "punctuation": "。"
    }
  ]
}